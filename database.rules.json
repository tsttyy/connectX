{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "chat_rooms": {
      "$roomId": {
        // Enforce that a user can only read/write chat rooms that contain their UID
        ".read": "auth != null && $roomId.contains(auth.uid)",
        ".write": "auth != null && $roomId.contains(auth.uid)"
      }
    }
  }
}
